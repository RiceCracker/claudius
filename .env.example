# claudius configuration – copy to .env and adjust

# ── Resources ─────────────────────────────────────────────────────────────────
CLAUDIUS_MEMORY=4g
CLAUDIUS_CPUS=4

# ── Network ───────────────────────────────────────────────────────────────────
CLAUDIUS_DNS="1.1.1.1 1.0.0.1 8.8.8.8 8.8.4.4"

# All TCP routes through Envoy – only listed host:port pairs pass.
# Empty = all TCP blocked. Proto suffix always required (/tcp or /udp).
CLAUDIUS_ALLOW="
  ntp.ubuntu.com:123/udp
  deb.debian.org:80/tcp
  security.debian.org:80/tcp
  *:443/tcp
  *:80/tcp
"

# ── Forwarding ────────────────────────────────────────────────────────────────
CLAUDIUS_SSH=0
CLAUDIUS_GPG=0
CLAUDIUS_CLIPBOARD=1

# ── Docker ────────────────────────────────────────────────────────────────────
CLAUDIUS_DOCKER_WRITE=1

# ── sudo ──────────────────────────────────────────────────────────────────────
CLAUDIUS_SUDO=1
CLAUDIUS_SUDO_CMDS="apt apt-get pip pip3 npm tcpdump"
