# claudius configuration – copy to .env and adjust

# ── Resources ─────────────────────────────────────────────────────────────────
CLAUDIUS_MEMORY=4g
CLAUDIUS_CPUS=4

# ── Network ───────────────────────────────────────────────────────────────────
CLAUDIUS_DNS="1.1.1.1 1.0.0.1 8.8.8.8 8.8.4.4"

# 1 = print each firewall rule at startup (useful for debugging)
CLAUDIUS_FIREWALL_VERBOSE=0

# Allowed outbound destinations. *.anthropic.com:443 is always open.
# Proto suffix required (/tcp or /udp). Empty = all TCP blocked.
# TCP routes through Envoy (host-filtered). UDP resolved at startup via iptables.
CLAUDIUS_ALLOW="
  # all HTTPS
  *:443/tcp
  # all HTTP
  *:80/tcp
  # Gemini MCP (built-in)
  generativelanguage.googleapis.com:443/tcp
  # exact domain
  # api.github.com:443/tcp
  # subdomain wildcard
  # *.npmjs.org:443/tcp
  # IP address
  # 1.2.3.4:5432/tcp
  # UDP
  # ntp.pool.org:123/udp
"

# ── Features ──────────────────────────────────────────────────────────────────
CLAUDIUS_SSH=0        # 1 = forward SSH agent (TCP/22 always open when enabled)
CLAUDIUS_GPG=0        # 1 = forward GPG agent socket
CLAUDIUS_CLIPBOARD=1  # 0 = disable clipboard forwarding (Wayland/X11)

# 1 = enable write ops (run/build/stop/exec/kill/commit) via socket proxy
# WARNING: combining with CLAUDIUS_SUDO=1 is equivalent to host root
CLAUDIUS_DOCKER_WRITE=0

# 1 = passwordless sudo for listed commands (lifts no-new-privs; caps stay bounded)
CLAUDIUS_SUDO=0
CLAUDIUS_SUDO_CMDS="apt apt-get pip pip3 npm"

# ── Extending ─────────────────────────────────────────────────────────────────
# Custom image extending FROM claudius (see docker/claudius/Dockerfile.*.example)
# CLAUDIUS_IMAGE=claudius-go

# Shell script run as root before Claude starts – for git config, aliases, etc.
# CLAUDIUS_USER_INIT=/home/you/dotfiles/claudius-init.sh
