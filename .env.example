# claudius configuration – copy to .env and adjust

# ── Resources ─────────────────────────────────────────────────────────────────
CLAUDIUS_MEMORY=4g
CLAUDIUS_CPUS=4

# ── Network ───────────────────────────────────────────────────────────────────
CLAUDIUS_DNS="1.1.1.1 1.0.0.1 8.8.8.8 8.8.4.4"

# Print individual firewall rules at startup (0 = only show "Firewall initializing...")
CLAUDIUS_FIREWALL_VERBOSE=0

# All TCP routes through Envoy – only listed host:port pairs pass.
# Empty = all TCP blocked. Proto suffix always required (/tcp or /udp).
CLAUDIUS_ALLOW="
  ntp.ubuntu.com:123/udp
  deb.debian.org:80/tcp
  security.debian.org:80/tcp
  *:443/tcp
  *:80/tcp
"

# ── Forwarding ────────────────────────────────────────────────────────────────
CLAUDIUS_SSH=0
CLAUDIUS_GPG=0
CLAUDIUS_CLIPBOARD=1

# ── Docker ────────────────────────────────────────────────────────────────────
# WARNING: CLAUDIUS_DOCKER_WRITE=1 combined with CLAUDIUS_SUDO=1 is equivalent
# to host root – a privileged container mounting the host filesystem becomes
# possible. Never enable both in the same session.
CLAUDIUS_DOCKER_WRITE=0

# ── sudo ──────────────────────────────────────────────────────────────────────
# Lifts no-new-privs; capabilities remain bounded (no NET_ADMIN, no SYS_ADMIN).
# tcpdump: needs root to capture on all interfaces (CAP_NET_RAW is present but
# the binary requires uid 0 for unrestricted interface access).
CLAUDIUS_SUDO=0
CLAUDIUS_SUDO_CMDS="apt apt-get pip pip3 npm tcpdump"
