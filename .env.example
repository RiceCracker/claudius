# claudius configuration – copy to .env and adjust

# ── Resources ─────────────────────────────────────────────────────────────────
CLAUDIUS_MEMORY=4g
CLAUDIUS_CPUS=4

# ── Network ───────────────────────────────────────────────────────────────────
CLAUDIUS_DNS="1.1.1.1 1.0.0.1 8.8.8.8 8.8.4.4"

# Allowed outbound destinations. *.anthropic.com:443/tcp is always open.
# Proto suffix required (/tcp or /udp). Empty = all non-Anthropic TCP blocked.
# TCP: filtered by SNI/Host (wildcards supported).
# UDP: resolved to IPs at startup (no wildcard support).
#
# Two ways to configure — pick one:
#
# A) Inline string (simple, single profile):
CLAUDIUS_ALLOW="
  # pip / Python packages (needed when CLAUDIUS_SUDO_CMDS includes pip)
  pypi.org:443/tcp
  files.pythonhosted.org:443/tcp

  # Gemini MCP (built-in)
  generativelanguage.googleapis.com:443/tcp

  # uncomment as needed:
  # *:443/tcp                         all HTTPS
  # *:80/tcp                          all HTTP
  # api.github.com:443/tcp            exact domain
  # *.npmjs.org:443/tcp               subdomain wildcard
  # 1.2.3.4:5432/tcp                  IP address
  # ntp.pool.org:123/udp              UDP (resolved to IP at startup)
"

# B) External file with named profiles (see allow.example.ini):
# CLAUDIUS_ALLOW_FILE=~/.config/claudius/allow.ini
# CLAUDIUS_ALLOW_PROFILE=flutter        # [default] is always included

# ── Features ──────────────────────────────────────────────────────────────────
CLAUDIUS_NO_PROXY=0   # 1 = skip proxy sidecar entirely (unrestricted outbound network)
CLAUDIUS_SSH=0        # 1 = forward SSH agent (opens *:22/tcp)
CLAUDIUS_GPG=0        # 1 = forward GPG agent socket
CLAUDIUS_CLIPBOARD=1  # 0 = disable clipboard forwarding (Wayland/X11)

# 1 = enable Docker write ops (run/build/stop/exec/...) via socket proxy
# WARNING: combining with CLAUDIUS_SUDO=1 is equivalent to host root
CLAUDIUS_DOCKER_WRITE=0

# 1 = passwordless sudo for listed commands (lifts no-new-privs; caps stay bounded)
CLAUDIUS_SUDO=0
CLAUDIUS_SUDO_CMDS="apt apt-get pip pip3 npm"

# ── Runtime ───────────────────────────────────────────────────────────────────
# CLAUDIUS_RUNTIME=runsc   # gVisor – run: make gvisor

# ── Extending ─────────────────────────────────────────────────────────────────
# CLAUDIUS_IMAGE=claudius-go
# CLAUDIUS_USER_INIT=/home/you/dotfiles/claudius-init.sh
