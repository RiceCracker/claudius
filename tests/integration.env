# Integration test environment – used by tests/integration.sh via CLAUDIUS_ENV_FILE.
# Intentionally restrictive: only what the tests explicitly need is allowed.
#
# Always allowed by claudius.sh regardless of this file:
#   *.anthropic.com:443/tcp  (hardcoded)
#   $CLAUDIUS_DNS:53/tcp+udp (auto-added per resolver)

# One extra host to verify CLAUDIUS_ALLOW works end-to-end.
CLAUDIUS_ALLOW="httpbin.org:443/tcp 9.9.9.9:53/udp"

CLAUDIUS_DNS="1.1.1.1 8.8.8.8"
CLAUDIUS_MEMORY="256m"
CLAUDIUS_CPUS="1"
CLAUDIUS_CLIPBOARD=0
CLAUDIUS_SSH=0
CLAUDIUS_GPG=0
